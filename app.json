{
  "expo": {
    "name": "RahiApp",
    "slug": "RahiApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rahiapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rahiapp.ride",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RahiApp needs access to your location to show nearby rides and provide navigation.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RahiApp needs access to your location to show nearby rides and provide navigation.",
        "NSLocationAlwaysUsageDescription": "RahiApp needs access to your location for ride tracking."
      },
      "jsEngine": "jsc",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F8A5F"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png", 
        "backgroundImage": "./assets/images/android-icon-background.png",
         "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.rahiapp.ride",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "jsEngine": "jsc",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F8A5F"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow RahiApp to use your location to find nearby rides."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F8A5F",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#0B0F19"
          }
        }
      ],
      "expo-font",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}